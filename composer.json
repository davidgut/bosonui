{
    "name": "davidgut/boson",
    "description": "Minimal, well-designed, flexible Laravel Blade components.",
    "type": "library",
    "keywords": [
        "laravel",
        "blade",
        "components",
        "ui",
        "boson"
    ],
    "homepage": "https://github.com/davidgut/bosonui",
    "license": "MIT",
    "authors": [
        {
            "name": "David Gutierrez",
            "email": "hi@davidgut.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0 || ^13.0",
        "blade-ui-kit/blade-heroicons": "^2.6"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "DavidGut\\Boson\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DavidGut\\Boson\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DavidGut\\Boson\\BosonServiceProvider"
            ]
        }
    },
    "support": {
        "issues": "https://github.com/davidgut/bosonui/issues",
        "source": "https://github.com/davidgut/bosonui"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
